}

/* ==========================================
   ⚡ HEADER CON AURA ÍGNEA Y ELÉCTRICA
   ========================================== */
.zaza-header {
    text-align: center;
    padding: 60px 20px 40px;
    position: relative;
    background: 
        linear-gradient(180deg, rgba(0, 102, 255, 0.15) 0%, transparent 50%),
        linear-gradient(0deg, rgba(255, 26, 26, 0.2) 0%, transparent 60%);
    border-bottom: 3px solid var(--fuxia);
    box-shadow: 
        0 10px 40px rgba(255, 26, 26, 0.4),
        0 0 60px rgba(0, 102, 255, 0.2),
        inset 0 -10px 40px rgba(255, 26, 26, 0.1);
    position: relative;
    overflow: hidden;
}

.zaza-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, 
        transparent, 
        rgba(255, 26, 26, 0.2), 
        rgba(0, 102, 255, 0.2), 
        transparent
    );
    animation: electricSweep 4s ease-in-out infinite;
}

@keyframes electricSweep {
    0% { left: -100%; }
    50% { left: 100%; }
    100% { left: 100%; }
}

/* Logo con halo de fuego y hielo */
.logo-container {
    position: relative;
    display: inline-block;
    margin-bottom: 20px;
}

.logo-container::before {
    content: '';
    position: absolute;
    top: -15px;
    left: -15px;
    right: -15px;
    bottom: -15px;
    background: conic-gradient(
        from 0deg,
        var(--fuxia),
        var(--amarillo),
        var(--verde),
        var(--fuxia-dark),
        var(--fuxia)
    );
    border-radius: 25%;
    animation: fireRotate 3s linear infinite;
    z-index: -1;
    filter: blur(15px);
    opacity: 0.9;
}

.logo-container::after {
    content: '';
    position: absolute;
    top: -25px;
    left: -25px;
    right: -25px;
    bottom: -25px;
    background: conic-gradient(
        from 180deg,
        var(--verde),
        var(--verde-glow),
        var(--fuxia),
        var(--verde)
    );
    border-radius: 25%;
    animation: fireRotate 5s linear infinite reverse;
    z-index: -2;
    filter: blur(25px);
    opacity: 0.5;
}

@keyframes fireRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.logo-img {
    width: 180px !important;
    height: 180px !important;
    border-radius: 25%;
    object-fit: cover;
    border: 4px solid var(--amarillo);
    box-shadow: 
        0 0 30px var(--fuxia),
        0 0 60px var(--fuxia-dark),
        0 0 90px var(--verde),
        inset 0 0 30px rgba(255, 26, 26, 0.3);
    animation: emberPulse 2s ease-in-out infinite;
}

@keyframes emberPulse {
    0%, 100% { 
        transform: scale(1);
        box-shadow: 
            0 0 30px var(--fuxia),
            0 0 60px var(--fuxia-dark),
            0 0 90px var(--verde);
    }
    50% { 
        transform: scale(1.03);
        box-shadow: 
            0 0 40px var(--fuxia),
            0 0 80px var(--amarillo),
            0 0 120px var(--verde-glow);
    }
}

/* Título con degradado fuego-hielo */
.zaza-title {
    font-size: 4rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 8px;
    background: linear-gradient(
        45deg,
        var(--fuxia) 0%,
        var(--amarillo) 25%,
        var(--verde-glow) 50%,
        var(--verde) 75%,
        var(--fuxia) 100%
    );
    background-size: 300% 300%;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: fireIceShift 4s ease infinite;
    text-shadow: 0 0 30px rgba(255, 26, 26, 0.5);
    margin-top: 20px;
    position: relative;
}

.zaza-title::after {
    content: 'IL Benedetto';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(255, 255, 255, 0.8) 50%,
        transparent 100%
    );
    -webkit-background-clip: text;
    background-clip: text;
    animation: textShine 3s ease-in-out infinite;
    opacity: 0.3;
}

@keyframes fireIceShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

@keyframes textShine {
    0%, 100% { transform: translateX(-100%); }
    50% { transform: translateX(100%); }
}

/* Subtítulo ceniza azul */
.zaza-subtitle {
    color: var(--verde);
    font-size: 1.3rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-top: 10px;
    text-shadow: 
        0 0 10px var(--verde),
        0 0 20px var(--verde-glow);
    animation: electricFlicker 4s ease-in-out infinite;
}

@keyframes electricFlicker {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.8; text-shadow: 0 0 20px var(--verde-glow), 0 0 40px var(--verde); }
    52% { opacity: 1; }
    54% { opacity: 0.9; }
}

/* Slogan con brasa */
.zaza-slogan {
    color: var(--amarillo);
    font-size: 1.1rem;
    font-style: italic;
    margin-top: 15px;
    text-shadow: 
        0 0 15px rgba(255, 69, 0, 0.6),
        0 0 30px rgba(255, 26, 26, 0.4);
    animation: emberGlow 3s ease-in-out infinite alternate;
}

@keyframes emberGlow {
    from { 
        text-shadow: 0 0 15px rgba(255, 69, 0, 0.6);
        color: var(--amarillo);
    }
    to { 
        text-shadow: 
            0 0 25px rgba(255, 107, 53, 0.9),
            0 0 50px rgba(255, 26, 26, 0.6);
        color: var(--amarillo-glow);
    }
}

/* ==========================================
   🔥 BOTÓN PRINCIPAL - ACCESO ÍGNEO
   ========================================== */
.access-btn {
    display: inline-block;
    margin-top: 40px;
    padding: 18px 50px;
    background: linear-gradient(135deg, var(--fuxia) 0%, var(--fuxia-dark) 100%);
    color: white;
    border: none;
    border-radius: 50px;
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    cursor: pointer;
    box-shadow: 
        0 0 20px var(--fuxia),
        0 0 40px rgba(255, 26, 26, 0.5),
        inset 0 0 20px rgba(255, 107, 53, 0.3);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
    border: 2px solid transparent;
    background-clip: padding-box;
}

.access-btn::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(45deg, var(--fuxia), var(--amarillo), var(--verde), var(--fuxia));
    border-radius: 50px;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s;
}

.access-btn::after {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
    transition: left 0.5s;
}

.access-btn:hover::before {
    opacity: 1;
    animation: borderRotate 2s linear infinite;
}

.access-btn:hover::after {
    left: 100%;
}

.access-btn:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 
        0 0 40px var(--fuxia),
        0 0 80px rgba(255, 26, 26, 0.7),
        0 0 120px rgba(0, 102, 255, 0.3);
    letter-spacing: 4px;
}

@keyframes borderRotate {
    0% { filter: hue-rotate(0deg); }
    100% { filter: hue-rotate(360deg); }
}

/* ==========================================
   💎 TARJETA DE PERFIL - CRISTAL DE HIELO
   ========================================== */
.perfil-card {
    background: 
        linear-gradient(135deg, rgba(255, 26, 26, 0.15) 0%, rgba(0, 102, 255, 0.1) 50%, rgba(31, 31, 46, 0.8) 100%);
    border: 2px solid var(--verde);
    border-radius: 20px;
    padding: 25px;
    width: 350px;
    color: #fff;
    box-shadow: 
        0 10px 30px rgba(0, 102, 255, 0.2),
        0 0 40px rgba(255, 26, 26, 0.1),
        inset 0 0 30px rgba(0, 102, 255, 0.05);
    backdrop-filter: blur(10px);
    animation: frostIn 1s ease;
    position: relative;
    overflow: hidden;
}

.perfil-card::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: conic-gradient(
        from 0deg,
        transparent,
        var(--fuxia),
        transparent,
        var(--verde),
        transparent
    );
    animation: slowRotate 15s linear infinite;
    opacity: 0.08;
    z-index: -1;
}

@keyframes frostIn {
    from { 
        opacity: 0; 
        transform: translateY(30px) scale(0.95);
        filter: blur(10px);
    }
    to { 
        opacity: 1; 
        transform: translateY(0) scale(1);
        filter: blur(0);
    }
}

@keyframes slowRotate {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.perfil-foto {
    width: 70px;
    height: 70px;
    border-radius: 25%;
    border: 3px solid var(--verde);
    object-fit: cover;
    box-shadow: 
        0 0 15px var(--verde),
        0 0 30px rgba(0, 102, 255, 0.3);
    transition: all 0.3s;
}

.perfil-foto:hover {
    transform: scale(1.1);
    box-shadow: 
        0 0 25px var(--verde-glow),
        0 0 50px rgba(0, 204, 255, 0.5);
}

.nombre {
    font-size: 1.3em;
    font-weight: bold;
    color: var(--amarillo);
    text-shadow: 
        0 0 10px rgba(255, 69, 0, 0.5),
        0 0 20px rgba(255, 26, 26, 0.3);
}

.badge {
    background: linear-gradient(90deg, var(--fuxia), var(--verde));
    color: #fff !important;
    font-size: 0.8em;
    padding: 4px 10px;
    border-radius: 8px;
    margin-left: 8px;
    font-weight: 700;
    box-shadow: 
        0 0 15px rgba(255, 26, 26, 0.5),
        0 0 30px rgba(0, 102, 255, 0.3);
    animation: badgePulse 2s infinite;
}

@keyframes badgePulse {
    0%, 100% { box-shadow: 0 0 15px rgba(255, 26, 26, 0.5); }
    50% { box-shadow: 0 0 25px rgba(0, 204, 255, 0.8); }
}

.online-dot {
    width: 25px !important;
    height: 20px !important;
    background: red !important;
    border-radius: 25%;
    border: 2px solid #111;
    box-shadow: 
        0 0 10px var(--verde-glow),
        0 0 20px var(--verde);
    animation: electricPulse 2s infinite;
}

@keyframes electricPulse {
    0% { 
        transform: scale(1); 
        box-shadow: 0 0 0 0 rgba(0, 204, 255, 0.7);
    }
    70% { 
        transform: scale(1.2); 
        box-shadow: 0 0 0 15px rgba(0, 204, 255, 0);
    }
    100% { 
        transform: scale(1); 
        box-shadow: 0 0 0 0 rgba(0, 204, 255, 0);
    }
}

/* ==========================================
   🎵 REPRODUCTOR - HORNO DE SONIDO
   ========================================== */
.zaza-player {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background: 
        linear-gradient(135deg, rgba(255, 26, 26, 0.2), rgba(0, 102, 255, 0.15));
    padding: 25px;
    border-radius: 20px;
    border: 2px solid var(--fuxia);
    box-shadow: 
        0 0 30px rgba(255, 26, 26, 0.3),
        0 0 60px rgba(0, 102, 255, 0.1),
        inset 0 0 30px rgba(255, 69, 0, 0.05);
    position: relative;
}

.zaza-player::before {
    content: '';
    position: absolute;
    inset: -2px;
    border-radius: 22px;
    background: linear-gradient(45deg, var(--fuxia), var(--verde), var(--fuxia));
    z-index: -1;
    opacity: 0.5;
    filter: blur(10px);
}

.player-container {
    position: relative;
    display: inline-block;
    border-radius: 15px;
    overflow: hidden;
    box-shadow: 
        0 0 30px rgba(0, 0, 0, 0.8),
        0 0 60px rgba(255, 26, 26, 0.2);
    width: 400px;
    height: 225px;
    background: #000;
    border: 2px solid var(--gris);
}

.player-bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    background: rgba(13, 13, 13, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    z-index: 2;
    border-bottom: 2px solid var(--fuxia);
    box-shadow: 0 5px 20px rgba(255, 26, 26, 0.3);
}

.play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: linear-gradient(135deg, var(--fuxia), var(--fuxia-dark));
    color: #fff;
    font-size: 28px;
    width: 80px;
    height: 80px;
    border: none;
    border-radius: 25%;
    cursor: pointer;
    box-shadow: 
        0 0 30px var(--fuxia),
        0 0 60px rgba(255, 26, 26, 0.5),
        inset 0 0 20px rgba(255, 107, 53, 0.3);
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    border: 3px solid var(--amarillo);
}

.play-btn:hover {
    transform: translate(-50%, -50%) scale(1.1);
    background: linear-gradient(135deg, var(--verde), var(--verde-glow));
    box-shadow: 
        0 0 40px var(--verde),
        0 0 80px rgba(0, 204, 255, 0.6);
    border-color: var(--verde-glow);
}

/* ==========================================
   📀 CARDS DE ÁLBUMES - BRASAS CRISTALIZADAS
   ========================================== */
.album-zaza {
    background: 
        linear-gradient(135deg, rgba(255, 26, 26, 0.08) 0%, rgba(0, 102, 255, 0.05) 100%);
    border: 2px solid transparent;
    border-radius: 20px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    animation: emberRise 0.6s ease;
    background-clip: padding-box;
}

.album-zaza::before {
    content: '';
    position: absolute;
    top: -2px;
    left: -2px;
    right: -2px;
    bottom: -2px;
    background: linear-gradient(
        45deg,
        var(--fuxia),
        var(--verde),
        var(--amarillo),
        var(--fuxia-dark),
        var(--fuxia)
    );
    border-radius: 20px;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s;
    background-size: 300% 300%;
    animation: borderFlow 3s ease infinite;
}

.album-zaza:hover::before {
    opacity: 1;
}

@keyframes borderFlow {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
}

.album-zaza:hover {
    transform: translateY(-10px) scale(1.02);
    box-shadow: 
        0 20px 40px rgba(255, 26, 26, 0.3),
        0 0 60px rgba(0, 102, 255, 0.2),
        0 0 100px rgba(255, 69, 0, 0.1);
}

@keyframes emberRise {
    from { 
        opacity: 0;
        transform: translateY(50px);
        filter: blur(10px);
    }
    to { 
        opacity: 1;
        transform: translateY(0);
        filter: blur(0);
    }
}

.album-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.5s;
    filter: contrast(1.1) saturate(1.2) brightness(0.9);
}

.album-zaza:hover .album-img {
    transform: scale(1.1);
    filter: contrast(1.3) saturate(1.5) brightness(1.1);
}

.album-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
        to top,
        rgba(13, 13, 13, 0.95) 0%,
        rgba(139, 0, 0, 0.3) 50%,
        transparent 100%
    );
    opacity: 0;
    transition: opacity 0.3s;
}

.album-zaza:hover .album-overlay {
    opacity: 1;
}

.album-info {
    padding: 25px;
    background: rgba(13, 13, 13, 0.9);
    border-top: 1px solid var(--gris);
    position: relative;
}

.album-info::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--fuxia), var(--verde), transparent);
    opacity: 0.5;
}

.album-title {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--amarillo);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-shadow: 
        0 0 10px rgba(255, 69, 0, 0.5),
        0 0 20px rgba(255, 26, 26, 0.3);
}

/* ==========================================
   🎛️ BOTONES DE PLATAFORMAS - ELEMENTOS
   ========================================== */
.btn-platform {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 15px;
    border-radius: 25px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.85rem;
    transition: all 0.3s;
    border: 2px solid transparent;
    position: relative;
    overflow: hidden;
}

.btn-platform::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: left 0.5s;
}

.btn-platform:hover::before {
    left: 100%;
}

.btn-spotify {
    background: linear-gradient(135deg, #1DB954, #1ed760);
    color: white;
    box-shadow: 0 4px 15px rgba(29, 185, 84, 0.3);
}

.btn-spotify:hover {
    box-shadow: 0 0 25px #1DB954, 0 0 50px rgba(29, 185, 84, 0.4);
    transform: translateY(-3px) scale(1.05);
    border-color: rgba(255, 255, 255, 0.3);
}

.btn-apple {
    background: linear-gradient(135deg, #FA243C, #ff4d6d);
    color: white;
    box-shadow: 0 4px 15px rgba(250, 36, 60, 0.3);
}

.btn-apple:hover {
    box-shadow: 0 0 25px #FA243C, 0 0 50px rgba(250, 36, 60, 0.4);
    transform: translateY(-3px) scale(1.05);
}

.btn-youtube {
    background: linear-gradient(135deg, #FF0000, #ff3333);
    color: white;
    box-shadow: 0 4px 15px rgba(255, 0, 0, 0.3);
}

.btn-youtube:hover {
    box-shadow: 0 0 25px #FF0000, 0 0 50px rgba(255, 0, 0, 0.4);
    transform: translateY(-3px) scale(1.05);
}

/* ==========================================
   🧊 MODALES - PORTALES DIMENSIONALES
   ========================================== */
.modal-content {
    background: 
        linear-gradient(135deg, #0d0d0d 0%, #1f1f2e 50%, #0d0d0d 100%);
    border: 3px solid transparent;
    border-radius: 20px;
    padding: 40px;
    max-width: 500px;
    width: 90%;
    box-shadow: 
        0 0 50px rgba(255, 26, 26, 0.3),
        0 0 100px rgba(0, 102, 255, 0.2),
        inset 0 0 50px rgba(0, 0, 0, 0.5);
    position: relative;
    animation: portalOpen 0.4s ease;
    background-clip: padding-box;
}

.modal-content::before {
    content: '';
    position: absolute;
    top: -3px;
    left: -3px;
    right: -3px;
    bottom: -3px;
    background: linear-gradient(45deg, var(--fuxia), var(--verde), var(--fuxia));
    border-radius: 22px;
    z-index: -1;
    animation: borderRotate 4s linear infinite;
}

@keyframes portalOpen {
    from { 
        transform: scale(0.8) rotateX(10deg);
        opacity: 0;
        filter: blur(20px);
    }
    to { 
        transform: scale(1) rotateX(0);
        opacity: 1;
        filter: blur(0);
    }
}

.modal-title {
    font-size: 2rem;
    color: var(--amarillo);
    text-align: center;
    margin-bottom: 30px;
    text-transform: uppercase;
    letter-spacing: 3px;
    text-shadow: 
        0 0 20px rgba(255, 69, 0, 0.6),
        0 0 40px rgba(255, 26, 26, 0.3);
    position: relative;
}

.modal-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: linear-gradient(90deg, var(--fuxia), var(--verde));
    margin: 15px auto 0;
    border-radius: 2px;
    box-shadow: 0 0 10px var(--fuxia);
}

.close-modal {
    position: absolute;
    top: 15px;
    right: 20px;
    font-size: 2rem;
    color: var(--fuxia);
    cursor: pointer;
    transition: all 0.3s;
    z-index: 10;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 25%;
}

.close-modal:hover {
    color: var(--verde-glow);
    transform: rotate(90deg) scale(1.2);
    background: rgba(255, 26, 26, 0.1);
    box-shadow: 0 0 20px rgba(0, 204, 255, 0.3);
}

/* ==========================================
   ✍️ INPUTS - RUNAS BRILLANTES
   ========================================== */
.zaza-input {
    width: 100%;
    padding: 15px 20px;
    margin-bottom: 20px;
    background: 
        linear-gradient(135deg, rgba(255, 26, 26, 0.05), rgba(0, 102, 255, 0.05));
    border: 2px solid var(--gris);
    border-radius: 12px;
    color: white;
    font-size: 1rem;
    transition: all 0.3s;
    outline: none;
    font-family: 'Poppins', sans-serif;
    position: relative;
}

.zaza-input:focus {
    border-color: var(--verde);
    box-shadow: 
        0 0 20px rgba(0, 102, 255, 0.4),
        0 0 40px rgba(0, 204, 255, 0.2),
        inset 0 0 10px rgba(0, 102, 255, 0.1);
    transform: scale(1.02);
    background: 
        linear-gradient(135deg, rgba(255, 26, 26, 0.08), rgba(0, 102, 255, 0.08));
}

.zaza-input::placeholder {
    color: rgba(255, 255, 255, 0.3);
    font-style: italic;
}

/* ==========================================
   🔘 BOTONES PRINCIPALES - FORJA
   ========================================== */
.zaza-btn {
    width: 100%;
