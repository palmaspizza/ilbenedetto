// GUARDAR ÁLBUM/CANCIÓN (CREAR O EDITAR) - CORREGIDO
// ==========================================
async function guardarAlbum() {
    if (guardando) {
        console.log('⏳ Ya se está guardando...');
        return;
    }

    const id = document.getElementById('albumId').value;
    const esEdicion = !!id;
    const titulo = document.getElementById('albumTitle').value.trim();

    if (!titulo) {
        alert('⚠️ El nombre del ÁLBUM/CANCIÓN es obligatorio');
        document.getElementById('albumTitle').focus();
        return;
    }

    // Verificar conexión a Firebase
    if (!db) {
        alert('❌ No hay conexión a la base de datos. Intenta recargar la página.');
        return;
    }

    guardando = true;
    const btn = document.getElementById('saveAlbumBtn');
    const textoOriginal = btn.innerHTML;
    btn.innerHTML = '⏳ Guardando...';
    btn.disabled = true;
    document.getElementById('loadingMsg').style.display = 'block';
    document.getElementById('successMsg').style.display = 'none';

    try {
        // Preparar datos
        const data = {
            title: titulo,
            description: document.getElementById('albumDesc').value.trim() || 'Sin descripción',
            links: {
                spotify: document.getElementById('linkSpotify').value.trim() || '',
                apple: document.getElementById('linkApple').value.trim() || '',
                soundcloud: document.getElementById('linkSoundCloud').value.trim() || '',
                youtube: document.getElementById('linkYouTube').value.trim() || '',
                audiomack: document.getElementById('linkAudiomack').value.trim() || ''
            },
            updatedAt: firebase.database.ServerValue.TIMESTAMP // Usar timestamp del servidor
        };

        // Manejar imagen
        if (fotoTemporal) {
            data.image = await comprimirImagen(fotoTemporal);
        } else if (esEdicion) {
            const existente = albumes.find(a => a.id === id);
            if (existente?.image) {
                data.image = existente.image;
            } else {
                data.image = 'https://i.ibb.co/Gv4Fw2NH/logobenedetto.jpg';
            }
        } else {
            data.image = 'https://i.ibb.co/Gv4Fw2NH/logobenedetto.jpg';
        }

        if (esEdicion) {
            // ========== EDITAR ==========
            console.log('✏️ Editando ÁLBUM/CANCIÓN:', id);
            
            await db.ref('albums/' + id).update(data);
            console.log('✅ Actualizado en Firebase');
            
        } else {
            // ========== CREAR NUEVO ==========
            console.log('🎵 Creando nuevo ÁLBUM/CANCIÓN');
            
            data.createdAt = firebase.database.ServerValue.TIMESTAMP;
            
            // Crear referencia con push() para obtener ID único
            const nuevoRef = db.ref('albums').push();
            await nuevoRef.set(data);
            console.log('✅ Creado en Firebase con ID:', nuevoRef.key);
        }

        // Mostrar éxito
        document.getElementById('loadingMsg').style.display = 'none';
        document.getElementById('successMsg').style.display = 'block';
        
        setTimeout(() => {
            closeModal('createModal');
            limpiarFormulario();
            // No necesitas llamar renderAlbumes() aquí porque el listener en tiempo real lo hará automáticamente
        }, 1500);

    } catch (error) {
        console.error('❌ Error guardando:', error);
        if (error.message.includes('permission_denied') || error.message.includes('PERMISSION_DENIED')) {
            alert('❌ ERROR DE PERMISOS: No tienes permiso para escribir en la base de datos. \n\nPor favor, asegúrate de que las Reglas de Firebase en la consola permitan escritura pública o que estés autenticado.');
        } else {
            alert('❌ Error al guardar: ' + error.message);
        }
        
        btn.disabled = false;
        btn.innerHTML = textoOriginal;
        document.getElementById('loadingMsg').style.display = 'none';
    } finally {
        guardando = false;
    }
}
        // Comprimir imagen para no saturar localStorage
        async function comprimirImagen(base64String) {
            return new Promise((resolve) => {
                const img = new Image();
                const canvas = document.createElement('canvas');
                const ctx = canvas.getContext('2d');

                img.onload = () => {
                    // Max 800px de ancho
                    const maxWidth = 800;
                    const scale = maxWidth / img.width;
                    const width = img.width > maxWidth ? maxWidth : img.width;
                    const height = img.width > maxWidth ? img.height * scale : img.height;

                    canvas.width = width;
                    canvas.height = height;
                    ctx.drawImage(img, 0, 0, width, height);

                    // Calidad 0.8 = buen balance calidad/peso
                    const compressed = canvas.toDataURL('image/jpeg', 0.8);
                    resolve(compressed);
                };

                img.src = base64String;
            });
        }

