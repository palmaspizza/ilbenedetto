    content: '';
    position: absolute;
    top: -12px; left: -12px; right: -12px; bottom: -12px;
    background: conic-gradient(
        from 0deg,
        #e84a00,
        #1a6fff,
        #0a3fa8,
        #e84a00,
        #ff6622,
        #1a6fff,
        #e84a00
    );
    border-radius: 25%;
    animation: logoRotate 4s linear infinite;
    z-index: -1;
    filter: blur(12px);
    opacity: 0.75;
}

.logo-container::after {
    content: '';
    position: absolute;
    top: -22px; left: -22px; right: -22px; bottom: -22px;
    background: conic-gradient(
        from 180deg,
        #0a3fa8,
        #1a6fff,
        #e84a00,
        #0a3fa8
    );
    border-radius: 25%;
    animation: logoRotate 7s linear infinite reverse;
    z-index: -2;
    filter: blur(22px);
    opacity: 0.35;
}

@keyframes logoRotate {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}

.logo-img {
    width: 220px !important;
    height: 220px !important;
    border-radius: 25%;
    object-fit: cover;
    border: 3px solid rgba(200, 169, 110, 0.6);
    box-shadow:
        0 0 25px rgba(232, 74, 0, 0.5),
        0 0 55px rgba(26, 111, 255, 0.35),
        0 0 90px rgba(232, 74, 0, 0.15);
    animation: logoPulse 3s ease-in-out infinite;
    filter: contrast(1.05) saturate(1.1);
}

@keyframes logoPulse {
    0%, 100% {
        box-shadow:
            0 0 25px rgba(232, 74, 0, 0.5),
            0 0 55px rgba(26, 111, 255, 0.35);
    }
    50% {
        box-shadow:
            0 0 40px rgba(232, 74, 0, 0.7),
            0 0 80px rgba(26, 111, 255, 0.5),
            0 0 120px rgba(200, 169, 110, 0.2);
    }
}

/* ==========================================
   TÍTULO
   ========================================== */
.zaza-title {
    font-size: 4rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 8px;
    background: linear-gradient(
