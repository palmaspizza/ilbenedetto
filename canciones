<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IL Benedetto | Estudio Musical</title>
    <link rel="icon" type="image/jpeg" href="https://i.ibb.co/Gv4Fw2NH/logobenedetto.jpg">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
    
    <!-- Firebase SDK -->
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>

    <style>
        :root {
            --fuxia: #003cff;
            --fuxia-dark: #000875;
            --verde: #702f2f;
            --verde-glow: #ff0000;
            --amarillo: #ffc400;
            --amarillo-glow: #FFD700;
            --negro: #0a0a0a;
            --gris: #1a1a1a;
            --danger: #6e0000;
            --success: #00c853;
        }
:root {
    /* 🔥 ROJO ÍGNEO (antes fuxia) - Llamas y calor */
    --fuxia: #ff1a1a;
    --fuxia-dark: #8b0000;
    
    /* ❄️ AZUL ELÉCTRICO (antes verde) - Cenizas y frío */
    --verde: #0066ff;
    --verde-glow: #00ccff;
    
    /* ⚡ AMARILLO MAGMA (antes amarillo) - Chispas y calor extremo */
    --amarillo: #ff4500;
    --amarillo-glow: #ff6b35;
    
    /* 🌑 CENIZA OSCURA - Fondos profundos */
    --negro: #0d0d0d;
    --gris: #1f1f2e;
    
    /* 💀 CENIZA CLARA - Textos secundarios */
    --danger: #ff0040;
    --success: #00d4ff;
}
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: var(--negro);
            font-family: 'Poppins', sans-serif;
            color: #fff;
            line-height: 1.6;
            overflow-x: hidden;
            position: relative;
        }

        /* Animación de humo en el fondo */
        .smoke-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            z-index: -1;
            pointer-events: none;
        }

        .smoke {
            position: absolute;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 80%, rgba(255, 20, 147, 0.15) 0%, transparent 50%),
                        radial-gradient(circle at 80% 20%, rgba(57, 255, 20, 0.1) 0%, transparent 50%),
                        radial-gradient(circle at 40% 40%, rgba(255, 255, 0, 0.08) 0%, transparent 50%);
            animation: smokeMove 20s ease-in-out infinite;
        }

        .smoke:nth-child(2) {
            animation-delay: -5s;
            opacity: 0.6;
        }

        .smoke:nth-child(3) {
            animation-delay: -10s;
            opacity: 0.4;
        }

        @keyframes smokeMove {
            0%, 100% {
                transform: translate(0, 0) scale(1);
                filter: blur(60px);
            }
            33% {
                transform: translate(30px, -30px) scale(1.1);
                filter: blur(80px);
            }
            66% {
                transform: translate(-20px, 20px) scale(0.9);
                filter: blur(70px);
            }
        }

        /* Header estilo IL Benedetto */
        .zaza-header {
            text-align: center;
            padding: 60px 20px 40px;
            position: relative;
            background: linear-gradient(135deg, rgba(255,20,147,0.2) 0%, rgba(57,255,20,0.1) 50%, rgba(255,255,0,0.15) 100%);
            border-bottom: 3px solid var(--fuxia);
            box-shadow: 0 10px 40px rgba(255, 20, 147, 0.3);
        }

        .logo-container {
            position: relative;
            display: inline-block;
            margin-bottom: 20px;
        }

        .logo-container::before {
            content: '';
            position: absolute;
            top: -10px;
            left: -10px;
            right: -10px;
            bottom: -10px;
            background: conic-gradient(from 0deg, var(--fuxia), var(--verde), var(--amarillo), var(--fuxia));
            border-radius: 25%;
            animation: rotate 4s linear infinite;
            z-index: -1;
            filter: blur(10px);
            opacity: 0.8;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .logo-img {
            width: 180px;
            height: 180px;
            border-radius: 25%;
            object-fit: cover;
            border: 4px solid var(--amarillo);
            box-shadow: 0 0 30px var(--fuxia), 0 0 60px var(--verde);
            animation: pulse 2s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .zaza-title {
            font-size: 4rem;
            font-weight: 800;
            text-transform: uppercase;
            letter-spacing: 8px;
            background: linear-gradient(45deg, var(--fuxia), var(--verde), var(--amarillo), var(--fuxia));
            background-size: 300% 300%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: gradientShift 3s ease infinite;
            text-shadow: 0 0 30px rgba(255, 20, 147, 0.5);
            margin-top: 20px;
        }

        @keyframes gradientShift {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .zaza-subtitle {
            color: var(--verde);
            font-size: 1.3rem;
            letter-spacing: 4px;
            text-transform: uppercase;
            margin-top: 10px;
            text-shadow: 0 0 10px var(--verde);
        }

        .zaza-slogan {
            color: var(--amarillo);
            font-size: 1.1rem;
            font-style: italic;
            margin-top: 15px;
            text-shadow: 0 0 15px rgba(255, 215, 0, 0.5);
            animation: glow 2s ease-in-out infinite alternate;
        }

        @keyframes glow {
            from { text-shadow: 0 0 10px rgba(255, 215, 0, 0.5); }
            to { text-shadow: 0 0 20px rgba(255, 215, 0, 0.8), 0 0 30px rgba(255, 215, 0, 0.6); }
        }

        /* Botón principal de acceso */
        .access-btn {
            display: inline-block;
            margin-top: 40px;
            padding: 18px 50px;
            background: linear-gradient(135deg, var(--fuxia) 0%, var(--fuxia-dark) 100%);
            color: white;
            border: none;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 3px;
            cursor: pointer;
            box-shadow: 0 0 20px var(--fuxia), 0 0 40px rgba(255, 20, 147, 0.4);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .access-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
            transition: left 0.5s;
        }

        .access-btn:hover::before {
            left: 100%;
        }

        .access-btn:hover {
            transform: translateY(-3px) scale(1.05);
            box-shadow: 0 0 30px var(--fuxia), 0 0 60px rgba(255, 20, 147, 0.6);
        }

        /* Tarjeta de perfil ZAZA */
        .perfil-section {
            display: flex;
            justify-content: center;
            margin: -60px auto 40px;
            position: relative;
            z-index: 10;
        }

        .perfil-card {
            background: linear-gradient(135deg, rgba(255,20,147,0.2) 0%, rgba(57,255,20,0.1) 50%, rgba(255,255,0,0.15) 100%);
            border: 2px solid var(--fuxia);
            border-radius: 20px;
            padding: 25px;
            width: 550px;
            color: #fff;
            box-shadow: 0 10px 30px rgb(65, 65, 65);
            backdrop-filter: blur(10px);
            animation: fadeInUp 1s ease;
            position: relative;
            overflow: hidden;
        }

        .perfil-card::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: conic-gradient(from 0deg, transparent, var(--fuxia), transparent, var(--verde), transparent);
            animation: rotate 10s linear infinite;
            opacity: 0.1;
            z-index: -1;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .perfil-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .perfil-foto {
            width: 70px;
            height: 70px;
            border-radius: 25%;
            border: 3px solid var(--verde);
            object-fit: cover;
            box-shadow: 0 0 15px var(--verde);
        }

        .perfil-info {
            flex-grow: 1;
            margin-left: 15px;
        }

        .nombre {
            font-size: 1.3em;
            font-weight: bold;
            color: var(--amarillo);
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
        }

        .badge {
            background: linear-gradient(90deg, var(--fuxia), var(--verde));
            color: #000;
            font-size: 0.8em;
            padding: 4px 10px;
            border-radius: 8px;
            margin-left: 8px;
            font-weight: 700;
            box-shadow: 0 0 10px rgba(255, 20, 147, 0.5);
        }

        .estado {
            font-style: italic;
            color: var(--verde);
            margin-top: 5px;
            font-size: 0.95rem;
            text-shadow: 0 0 5px var(--verde);
        }

        .online-dot {
            width: 14px;
            height: 14px;
            background: var(--verde);
            border-radius: 25%;
            border: 2px solid #111;
            box-shadow: 0 0 10px var(--verde);
            animation: pulse-dot 2s infinite;
        }

        @keyframes pulse-dot {
            0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(57, 255, 20, 0.7); }
            70% { transform: scale(1.2); box-shadow: 0 0 10px 10px rgba(57, 255, 20, 0); }
            100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(57, 255, 20, 0); }
        }

        .gif-container {
            margin-top: 15px;
            border-radius: 12px;
            overflow: hidden;
            border: 2px solid var(--fuxia);
        }

        .gif-container img {
            width: 100%;
            display: block;
        }

        /* Reproductor estilo ZAZA */
        .player-section {
            text-align: center;
            margin: 40px 20px;
        }

        .player-title {
            color: var(--amarillo);
            font-size: 1.5rem;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 3px;
            text-shadow: 0 0 15px var(--amarillo);
        }

        .zaza-player {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, rgba(255,20,147,0.2), rgba(57,255,20,0.1));
            padding: 25px;
            border-radius: 20px;
            border: 2px solid var(--fuxia);
            box-shadow: 0 0 30px rgba(255, 20, 147, 0.3);
        }

        .player-container {
            position: relative;
            display: inline-block;
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 0 30px rgba(0,0,0,0.8);
            width: 400px;
            height: 225px;
            background: #000;
        }

        .player-bar {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            background: rgba(0,0,0,0.8);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 10px;
            z-index: 2;
            border-bottom: 2px solid var(--fuxia);
        }

        .player-artist-img {
            width: 35px;
            height: 35px;
            border-radius: 25%;
            border: 2px solid var(--verde);
            position: absolute;
            left: 15px;
            box-shadow: 0 0 10px var(--verde);
        }

        .player-song-title {
            color: #fff;
            font-size: 16px;
            font-weight: bold;
            text-decoration: underline;
            text-decoration-color: var(--fuxia);
            margin-left: 40px;
        }

        .player-thumb {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.8;
        }

        .play-btn {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            background: var(--fuxia);
            color: #fff;
            font-size: 28px;
            width: 80px;
            height: 80px;
            border: none;
            border-radius: 25%;
            cursor: pointer;
            box-shadow: 0 0 30px var(--fuxia), 0 0 60px rgba(255, 20, 147, 0.5);
            transition: all 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 3;
        }

        .play-btn:hover {
            transform: translate(-50%, -50%) scale(1.1);
            background: var(--verde);
            box-shadow: 0 0 40px var(--verde);
        }

        .play-btn.playing {
            background: #444;
            box-shadow: 0 0 20px rgba(255,255,255,0.3);
        }

        /* Modales */
        .modal-overlay {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.95);
            backdrop-filter: blur(10px);
            z-index: 1000;
            justify-content: center;
            align-items: center;
            animation: fadeIn 0.3s ease;
        }

        .modal-overlay.active {
            display: flex;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .modal-content {
            background: linear-gradient(135deg, #1a1a1a 0%, #2d1b2e 100%);
            border: 3px solid var(--fuxia);
            border-radius: 20px;
            padding: 40px;
            max-width: 500px;
            width: 90%;
            box-shadow: 0 0 50px var(--fuxia), 0 0 100px rgba(57, 255, 20, 0.3);
            position: relative;
            animation: slideUp 0.4s ease;
            max-height: 90vh;
            overflow-y: auto;
        }

        @keyframes slideUp {
            from { transform: translateY(50px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .modal-title {
            font-size: 2rem;
            color: var(--amarillo);
            text-align: center;
            margin-bottom: 30px;
            text-transform: uppercase;
            letter-spacing: 3px;
            text-shadow: 0 0 20px var(--amarillo);
        }

        .close-modal {
            position: absolute;
            top: 15px;
            right: 20px;
            font-size: 2rem;
            color: var(--fuxia);
            cursor: pointer;
            transition: all 0.3s;
            z-index: 10;
        }

        .close-modal:hover {
            color: var(--verde);
            transform: rotate(90deg);
        }

        /* Inputs estilo ZAZA */
        .zaza-input {
            width: 100%;
            padding: 15px 20px;
            margin-bottom: 20px;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid var(--fuxia);
            border-radius: 12px;
            color: white;
            font-size: 1rem;
            transition: all 0.3s;
            outline: none;
            font-family: 'Poppins', sans-serif;
        }

        .zaza-input:focus {
            border-color: var(--verde);
            box-shadow: 0 0 20px rgba(57, 255, 20, 0.4);
            transform: scale(1.02);
        }

        .zaza-input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .zaza-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--verde) 0%, var(--verde-glow) 100%);
            color: black;
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 0 20px rgba(57, 255, 20, 0.4);
            font-family: 'Poppins', sans-serif;
        }

        .zaza-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 30px var(--verde);
        }

        .zaza-btn:disabled {
            background: #444;
            color: #888;
            cursor: not-allowed;
            box-shadow: none;
            transform: none;
        }

        /* Botón de editar/eliminar */
        .zaza-btn-secondary {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--fuxia) 0%, var(--fuxia-dark) 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 0 20px rgba(255, 20, 147, 0.4);
            font-family: 'Poppins', sans-serif;
            margin-top: 15px;
        }

        .zaza-btn-secondary:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 30px var(--fuxia);
        }

        .zaza-btn-danger {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, var(--danger) 0%, #cc0000 100%);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 2px;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 0 20px rgba(255, 23, 68, 0.4);
            font-family: 'Poppins', sans-serif;
            margin-top: 15px;
        }

        .zaza-btn-danger:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 30px var(--danger);
        }

        .error-msg {
            color: #ff4444;
            text-align: center;
            margin-top: 15px;
            display: none;
            font-weight: 600;
            animation: shake 0.5s;
        }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            25% { transform: translateX(-10px); }
            75% { transform: translateX(10px); }
        }

        /* Grid de ÁLBUM/CANCIÓNes */
        #albumes-container {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 30px;
            padding: 60px 20px;
            max-width: 1600px;
            margin: 0 auto;
        }

        .album-zaza {
            background: linear-gradient(135deg, rgba(255,20,147,0.1) 0%, rgba(57,255,20,0.05) 100%);
            border: 2px solid var(--fuxia);
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative;
            animation: fadeInUp 0.6s ease;
        }

        .album-zaza::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, var(--fuxia), var(--verde), var(--amarillo), var(--fuxia));
            border-radius: 20px;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .album-zaza:hover::before {
            opacity: 1;
        }

        .album-zaza:hover {
            transform: translateY(-10px) scale(1.02);
            box-shadow: 0 20px 40px rgba(255, 20, 147, 0.3);
        }

        /* Modo eliminar overlay */
        .modo-eliminar-overlay {
            position: absolute;
            inset: 0;
            background: rgba(255, 23, 68, 0.3);
            z-index: 5;
            display: none;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }

        .modo-eliminar-activo .modo-eliminar-overlay {
            display: flex;
        }

        .modo-eliminar-badge {
            background: var(--danger);
            color: white;
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 1.2rem;
            animation: pulse 1s infinite;
        }

        .album-img-container {
            position: relative;
            width: 100%;
            aspect-ratio: 1 / 1;
            overflow: hidden;
        }

        .album-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: all 0.5s;
            filter: contrast(1.1) saturate(1.2);
        }

        .album-zaza:hover .album-img {
            transform: scale(1.1);
            filter: contrast(1.2) saturate(1.4) brightness(1.1);
        }

        .album-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 50%);
            opacity: 0;
            transition: opacity 0.3s;
        }

        .album-zaza:hover .album-overlay {
            opacity: 1;
        }

        .album-info {
            padding: 25px;
            background: rgba(0, 0, 0, 0.8);
        }

        .album-title {
            font-size: 1.4rem;
            font-weight: 800;
            color: var(--amarillo);
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-shadow: 0 0 10px var(--amarillo);
        }

        .album-desc {
            color: #ccc;
            font-size: 0.9rem;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        /* Botones de plataformas */
        .botones-zaza {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            justify-content: center;
        }

        .btn-platform {
            display: flex;
            align-items: center;
            gap: 6px;
            padding: 10px 15px;
            border-radius: 25px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.85rem;
            transition: all 0.3s;
            border: 2px solid transparent;
        }

        .btn-spotify {
            background: #1DB954;
            color: white;
        }

        .btn-spotify:hover {
            box-shadow: 0 0 20px #1DB954;
            transform: translateY(-2px);
        }

        .btn-apple {
            background: #FA243C;
            color: white;
        }

        .btn-apple:hover {
            box-shadow: 0 0 20px #FA243C;
            transform: translateY(-2px);
        }

        .btn-soundcloud {
            background: #FF5500;
            color: white;
        }

        .btn-soundcloud:hover {
            box-shadow: 0 0 20px #FF5500;
            transform: translateY(-2px);
        }

        .btn-youtube {
            background: #FF0000;
            color: white;
        }

        .btn-youtube:hover {
            box-shadow: 0 0 20px #FF0000;
            transform: translateY(-2px);
        }

        .btn-audiomack {
            background: #FFA200;
            color: black;
        }

        .btn-audiomack:hover {
            box-shadow: 0 0 20px #FFA200;
            transform: translateY(-2px);
        }

        .btn-platform img {
            width: 18px;
            height: 18px;
            filter: brightness(0) invert(1);
        }

        .btn-audiomack img {
