}

/* ==========================================
   TARJETA DE PERFIL
   ========================================== */
.perfil-section {
    display: flex;
    justify-content: center;
    margin: -60px auto 40px;
    position: relative;
    z-index: 10;
}

.perfil-card {
    background: linear-gradient(135deg, #111216 0%, #0e1018 100%);
    border: 1px solid rgba(26, 111, 255, 0.25);
    border-radius: 20px;
    padding: 25px;
    width: 350px;
    color: #d0cfc8;
    box-shadow:
        0 15px 40px rgba(0, 0, 0, 0.6),
        0 0 30px rgba(26, 111, 255, 0.08),
        inset 0 1px 0 rgba(255,255,255,0.03);
    backdrop-filter: blur(10px);
    animation: fadeInUp 1s ease;
    position: relative;
    overflow: hidden;
}

.perfil-card::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px; right: -1px; bottom: -1px;
    background: linear-gradient(135deg,
        rgba(26, 111, 255, 0.2) 0%,
        transparent 40%,
        transparent 60%,
        rgba(232, 74, 0, 0.1) 100%
    );
    border-radius: 20px;
    z-index: -1;
}

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
}

.perfil-foto {
    width: 70px;
    height: 70px;
    border-radius: 25%;
    border: 2px solid rgba(26, 111, 255, 0.5);
    object-fit: cover;
    box-shadow: 0 0 15px rgba(26, 111, 255, 0.3);
}

.perfil-info { flex-grow: 1; margin-left: 15px; }

.nombre {
    font-size: 1.2em;
    font-weight: bold;
    color: #c8a96e;
    letter-spacing: 0.5px;
}

.badge {
    background: linear-gradient(90deg, #1a3a80, #0a3fa8);
    color: #7aaeff;
    font-size: 0.75em;
    padding: 3px 9px;
    border-radius: 6px;
    margin-left: 8px;
    font-weight: 700;
    border: 1px solid rgba(26, 111, 255, 0.4);
}

.estado {
    font-style: italic;
    color: #5a8ae0;
    margin-top: 4px;
    font-size: 0.9rem;
}

.online-dot {
    width: 12px;
    height: 12px;
    background: #1a6fff;
    border-radius: 25%;
    border: 2px solid #0a0a0b;
    box-shadow: 0 0 8px rgba(26, 111, 255, 0.8);
    animation: onlinePulse 2.5s infinite;
}

@keyframes onlinePulse {
    0%   { box-shadow: 0 0 0 0 rgba(26, 111, 255, 0.6); }
    70%  { box-shadow: 0 0 0 12px rgba(26, 111, 255, 0); }
    100% { box-shadow: 0 0 0 0 rgba(26, 111, 255, 0); }
}

.social-icons {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 15px;
}

.social-icons a {
    width: 38px;
    height: 38px;
    border-radius: 25%;
    background: rgba(26, 111, 255, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(26, 111, 255, 0.25);
    transition: all 0.3s;
    color: #7aaeff;
    text-decoration: none;
    font-size: 1.1rem;
}

.social-icons a:hover {
    background: rgba(26, 111, 255, 0.2);
    transform: translateY(-4px) scale(1.05);
    box-shadow: 0 0 18px rgba(26, 111, 255, 0.4);
    border-color: rgba(26, 111, 255, 0.6);
}

/* ==========================================
   TÍTULO DE SECCIÓN
   ========================================== */
.section-title {
    text-align: center;
    font-size: 2rem;
    color: #c8a96e;
    margin: 40px 0 20px;
    text-transform: uppercase;
    letter-spacing: 6px;
    font-weight: 700;
    position: relative;
    display: inline-block;
    width: 100%;
    opacity: 0.9;
}

.section-title::after {
    content: '';
    display: block;
    width: 80px;
    height: 2px;
    background: linear-gradient(90deg, transparent, #1a6fff, #e84a00, transparent);
    margin: 12px auto;
    border-radius: 1px;
}

/* ==========================================
   GRID Y CARDS DE ÁLBUMES
   ========================================== */
#albumes-container {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 25px;
    padding: 50px 20px;
    max-width: 1600px;
    margin: 0 auto;
}

.album-zaza {
    background: #0e1018;
    border: 1px solid rgba(26, 111, 255, 0.15);
    border-radius: 16px;
    overflow: hidden;
    transition: all 0.35s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    animation: cardRise 0.5s ease;
}

.album-zaza::before {
    content: '';
    position: absolute;
    top: -1px; left: -1px; right: -1px; bottom: -1px;
    background: linear-gradient(
        135deg,
        rgba(26, 111, 255, 0.4),
        rgba(232, 74, 0, 0.3),
        rgba(26, 111, 255, 0.2)
    );
    border-radius: 16px;
    z-index: -1;
    opacity: 0;
    transition: opacity 0.3s;
    background-size: 200% 200%;
}

.album-zaza:hover::before { opacity: 1; }

.album-zaza:hover {
    transform: translateY(-8px) scale(1.01);
    box-shadow:
        0 20px 50px rgba(0, 0, 0, 0.7),
        0 0 30px rgba(26, 111, 255, 0.2),
        0 0 60px rgba(232, 74, 0, 0.1);
    border-color: rgba(26, 111, 255, 0.3);
}

@keyframes cardRise {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
}

.album-img-container {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
}

.album-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: all 0.5s;
    filter: contrast(1.05) saturate(0.9) brightness(0.85);
}

.album-zaza:hover .album-img {
    transform: scale(1.08);
    filter: contrast(1.1) saturate(1.1) brightness(1.0);
}

.album-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: linear-gradient(
        to top,
        rgba(10, 10, 11, 0.95) 0%,
        rgba(26, 111, 255, 0.15) 60%,
        transparent 100%
    );
    opacity: 0;
    transition: opacity 0.3s;
}

.album-zaza:hover .album-overlay { opacity: 1; }

.album-info {
    padding: 20px;
    background: #0e1018;
    border-top: 1px solid rgba(26, 111, 255, 0.12);
    position: relative;
}

.album-info::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(232, 74, 0, 0.4), rgba(26, 111, 255, 0.4), transparent);
}

.album-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #c8a96e;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.album-desc {
    color: #666672;
    font-size: 0.85rem;
    margin-bottom: 15px;
    line-height: 1.5;
}

/* ==========================================
   BOTONES DE PLATAFORMAS
   ========================================== */
.botones-zaza {
    display: flex;
    flex-wrap: wrap;
    gap: 7px;
    justify-content: center;
}

.btn-platform {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 8px 13px;
    border-radius: 20px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.82rem;
    transition: all 0.25s;
    border: 1px solid transparent;
    position: relative;
    overflow: hidden;
}

.btn-platform:hover {
    transform: translateY(-2px);
    filter: brightness(1.15);
}

.btn-platform img {
    width: 16px;
    height: 16px;
    filter: brightness(0) invert(1);
}

.btn-audiomack img { filter: none; }

.btn-spotify    { background: #1a3d24; color: #4caf6f; border-color: rgba(76, 175, 111, 0.3); }
.btn-spotify:hover { box-shadow: 0 0 18px rgba(29, 185, 84, 0.35); }

.btn-apple      { background: #3d1a1a; color: #e06060; border-color: rgba(250, 36, 60, 0.3); }
.btn-apple:hover { box-shadow: 0 0 18px rgba(250, 36, 60, 0.35); }

.btn-soundcloud { background: #3d2a1a; color: #e08040; border-color: rgba(255, 85, 0, 0.3); }
.btn-soundcloud:hover { box-shadow: 0 0 18px rgba(255, 85, 0, 0.35); }

.btn-youtube    { background: #3d1a1a; color: #e05050; border-color: rgba(255, 0, 0, 0.3); }
.btn-youtube:hover { box-shadow: 0 0 18px rgba(255, 0, 0, 0.35); }

.btn-audiomack  { background: #3d2e10; color: #c89030; border-color: rgba(255, 162, 0, 0.3); }
.btn-audiomack:hover { box-shadow: 0 0 18px rgba(255, 162, 0, 0.35); }

/* ==========================================
   ADMIN BUTTONS EN CARDS
   ========================================== */
.admin-btns {
    position: absolute;
    top: 10px; right: 10px;
    display: flex;
    gap: 7px;
    z-index: 10;
}

.admin-btn {
    width: 36px; height: 36px;
    border: none;
    border-radius: 25%;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.25s;
}

.admin-btn.edit   { background: #1a3a80; color: #7aaeff; }
.admin-btn.edit:hover  { box-shadow: 0 0 15px rgba(26, 111, 255, 0.5); }

.admin-btn.delete { background: #5a1a1a; color: #e06060; }
.admin-btn.delete:hover { box-shadow: 0 0 15px rgba(204, 34, 0, 0.5); }

/* ==========================================
   MODO ELIMINAR
   ========================================== */
.modo-eliminar-overlay {
    position: absolute;
    inset: 0;
    background: rgba(204, 34, 0, 0.25);
    z-index: 5;
    display: none;
    align-items: center;
    justify-content: center;
    pointer-events: none;
}

.modo-eliminar-activo .modo-eliminar-overlay { display: flex; }

.modo-eliminar-badge {
    background: rgba(90, 0, 0, 0.9);
    color: #ff9090;
    padding: 10px 18px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 0.95rem;
    border: 1px solid rgba(204, 34, 0, 0.5);
}

.modo-eliminar-banner {
    position: fixed;
    top: 0; left: 0; right: 0;
    background: linear-gradient(90deg, #3d0000, #5a0000, #3d0000);
    color: #ff9090;
    text-align: center;
    padding: 13px;
    z-index: 9999;
    font-weight: 700;
    border-bottom: 1px solid rgba(204, 34, 0, 0.4);
    display: none;
    letter-spacing: 1px;
}

.modo-eliminar-banner.active { display: block; }

.modo-eliminar-banner button {
    margin-left: 12px;
    padding: 6px 16px;
    border: 1px solid rgba(204, 34, 0, 0.5);
    background: transparent;
    color: #ff9090;
    border-radius: 15px;
    cursor: pointer;
    font-weight: 600;
}

.modo-eliminar-banner button:hover {
    background: rgba(204, 34, 0, 0.3);
}

/* ==========================================
   MODALES
   ========================================== */
.modal-overlay {
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    animation: modalFadeIn 0.25s ease;
}

.modal-overlay.active { display: flex; }

@keyframes modalFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
}

.modal-content {
    background: linear-gradient(160deg, #111216 0%, #0d0f14 100%);
    border: 1px solid rgba(26, 111, 255, 0.2);
    border-radius: 18px;
    padding: 40px;
    max-width: 500px;
    width: 90%;
    box-shadow:
        0 0 60px rgba(26, 111, 255, 0.15),
        0 30px 80px rgba(0, 0, 0, 0.8),
        inset 0 1px 0 rgba(255,255,255,0.03);
    position: relative;
    animation: modalSlideUp 0.3s ease;
    max-height: 90vh;
    overflow-y: auto;
}

@keyframes modalSlideUp {
    from { transform: translateY(40px); opacity: 0; }
    to   { transform: translateY(0); opacity: 1; }
}

.modal-title {
    font-size: 1.7rem;
    color: #c8a96e;
    text-align: center;
    margin-bottom: 28px;
    text-transform: uppercase;
    letter-spacing: 3px;
    font-weight: 700;
    position: relative;
}

.modal-title::after {
    content: '';
    display: block;
    width: 50px; height: 2px;
    background: linear-gradient(90deg, #e84a00, #1a6fff);
    margin: 12px auto 0;
    border-radius: 1px;
}

.close-modal {
    position: absolute;
    top: 15px; right: 18px;
    font-size: 1.6rem;
    color: #444458;
    cursor: pointer;
    transition: all 0.25s;
    width: 36px; height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 25%;
    z-index: 10;
}

.close-modal:hover {
    color: #7aaeff;
    transform: rotate(90deg);
    background: rgba(26, 111, 255, 0.1);
}

/* ==========================================
   INPUTS
   ========================================== */
.zaza-input {
    width: 100%;
    padding: 13px 18px;
    margin-bottom: 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(26, 111, 255, 0.2);
    border-radius: 10px;
    color: #c8c8d0;
    font-size: 0.95rem;
    transition: all 0.25s;
    outline: none;
    font-family: 'Poppins', sans-serif;
}

.zaza-input:focus {
    border-color: rgba(26, 111, 255, 0.5);
    box-shadow: 0 0 20px rgba(26, 111, 255, 0.12);
    background: rgba(26, 111, 255, 0.04);
}

.zaza-input::placeholder { color: rgba(255, 255, 255, 0.2); }

/* ==========================================
   BOTONES
   ========================================== */
.zaza-btn {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #1a3a80 0%, #0a2555 100%);
    color: #7aaeff;
    border: 1px solid rgba(26, 111, 255, 0.35);
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.25s;
    box-shadow: 0 0 20px rgba(26, 111, 255, 0.12);
    font-family: 'Poppins', sans-serif;
}

.zaza-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 30px rgba(26, 111, 255, 0.3);
    border-color: rgba(26, 111, 255, 0.6);
    color: #c0d8ff;
}

.zaza-btn:disabled {
    background: #1a1a22;
    color: #3a3a48;
    cursor: not-allowed;
    box-shadow: none;
    border-color: rgba(255,255,255,0.05);
    transform: none;
}

.zaza-btn-secondary {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #3d1a00 0%, #280f00 100%);
    color: #c07040;
    border: 1px solid rgba(232, 74, 0, 0.3);
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.25s;
    box-shadow: 0 0 20px rgba(232, 74, 0, 0.1);
    font-family: 'Poppins', sans-serif;
    margin-top: 12px;
}

.zaza-btn-secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 25px rgba(232, 74, 0, 0.25);
    border-color: rgba(232, 74, 0, 0.5);
    color: #e09060;
}

.zaza-btn-danger {
    width: 100%;
    padding: 14px;
    background: linear-gradient(135deg, #4a0a0a 0%, #300000 100%);
    color: #e06060;
    border: 1px solid rgba(204, 34, 0, 0.3);
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    cursor: pointer;
    transition: all 0.25s;
    font-family: 'Poppins', sans-serif;
    margin-top: 12px;
}

.zaza-btn-danger:hover {
    transform: translateY(-2px);
    box-shadow: 0 0 25px rgba(204, 34, 0, 0.3);
    border-color: rgba(204, 34, 0, 0.55);
    color: #ff9090;
}

/* ==========================================
   FORMULARIO - FILE INPUT
   ========================================== */
.form-grid { display: grid; gap: 12px; }

.file-label {
    display: block;
    padding: 18px;
    background: rgba(26, 111, 255, 0.04);
    border: 1px dashed rgba(26, 111, 255, 0.3);
    border-radius: 10px;
    text-align: center;
    cursor: pointer;
    transition: all 0.25s;
    color: #5a7acc;
    font-weight: 600;
}

.file-label:hover {
    background: rgba(26, 111, 255, 0.08);
    border-color: rgba(26, 111, 255, 0.5);
    color: #7aaeff;
}

.preview-img {
    max-width: 100%;
    max-height: 180px;
    border-radius: 8px;
    margin-top: 10px;
    display: none;
    border: 1px solid rgba(26, 111, 255, 0.3);
}

.loading {
    display: none;
    text-align: center;
    color: #5a8ae0;
    margin-top: 16px;
    font-weight: 600;
}

.loading::after {
    content: '';
    display: inline-block;
    width: 16px; height: 16px;
    border: 2px solid rgba(26, 111, 255, 0.3);
    border-top-color: #1a6fff;
    border-radius: 25%;
    margin-left: 8px;
    animation: spin 0.9s linear infinite;
    vertical-align: middle;
}

@keyframes spin { to { transform: rotate(360deg); } }

.success-msg {
    display: none;
    text-align: center;
    color: #5a8ae0;
    margin-top: 16px;
    font-weight: 700;
}

.error-msg {
    color: #cc5555;
    text-align: center;
    margin-top: 12px;
    display: none;
    font-weight: 600;
    animation: shake 0.4s;
}

@keyframes shake {
    0%, 100% { transform: translateX(0); }
    25%       { transform: translateX(-8px); }
    75%       { transform: translateX(8px); }
}

/* ==========================================
   ERROR Y ESTADO VACÍO
   ========================================== */
.error-container {
    text-align: center;
    color: #cc5555;
    padding: 40px;
    grid-column: 1/-1;
    background: rgba(204, 34, 0, 0.06);
    border: 1px solid rgba(204, 34, 0, 0.2);
    border-radius: 12px;
    margin: 20px;
}

.error-container button {
    margin-top: 15px;
    padding: 10px 24px;
    background: rgba(26, 111, 255, 0.15);
    color: #7aaeff;
    border: 1px solid rgba(26, 111, 255, 0.3);
    border-radius: 20px;
    cursor: pointer;
    font-weight: 600;
}

/* ==========================================
   DEBUG INFO
   ========================================== */
.debug-info {
    position: fixed;
    bottom: 10px; right: 10px;
    background: rgba(10, 10, 11, 0.9);
    color: #5a8ae0;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 0.75rem;
    font-family: monospace;
    border: 1px solid rgba(26, 111, 255, 0.15);
    max-width: 240px;
    z-index: 9999;
}

/* ==========================================
   REPRODUCTOR
   ========================================== */
.player-section { text-align: center; margin: 30px 20px; }

.player-title {
    color: #c8a96e;
    font-size: 1.3rem;
    margin-bottom: 18px;
    text-transform: uppercase;
    letter-spacing: 4px;
}

.zaza-player {
    display: inline-flex;
    justify-content: center;
    align-items: center;
    background: rgba(26, 111, 255, 0.06);
    padding: 20px;
    border-radius: 18px;
    border: 1px solid rgba(26, 111, 255, 0.18);
    box-shadow: 0 0 40px rgba(26, 111, 255, 0.08);
}

.player-container {
    position: relative;
    display: inline-block;
    border-radius: 12px;
    overflow: hidden;
    width: 400px;
    height: 225px;
    background: #000;
    border: 1px solid rgba(26, 111, 255, 0.15);
}

.player-bar {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    background: rgba(10, 10, 11, 0.95);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 10px;
    z-index: 2;
    border-bottom: 1px solid rgba(26, 111, 255, 0.25);
}

.player-artist-img {
    width: 32px; height: 32px;
    border-radius: 25%;
    border: 1px solid rgba(26, 111, 255, 0.4);
    position: absolute;
    left: 14px;
}

.player-song-title {
    color: #c8c8d0;
    font-size: 14px;
    font-weight: bold;
    margin-left: 38px;
}

.player-thumb {
    width: 100%; height: 100%;
    object-fit: cover;
    opacity: 0.7;
    filter: saturate(0.7);
}

.play-btn {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    background: linear-gradient(135deg, #1a3a80, #0a2555);
    color: #7aaeff;
    font-size: 26px;
    width: 72px; height: 72px;
    border: 2px solid rgba(200, 169, 110, 0.4);
    border-radius: 25%;
    cursor: pointer;
    box-shadow: 0 0 25px rgba(26, 111, 255, 0.4);
    transition: all 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
}

.play-btn:hover {
    transform: translate(-50%, -50%) scale(1.08);
    background: linear-gradient(135deg, #3d1a00, #280f00);
    color: #e09060;
    box-shadow: 0 0 40px rgba(232, 74, 0, 0.5);
    border-color: rgba(232, 74, 0, 0.5);
}

/* ==========================================
   SECCIÓN DE VIDEO
   ========================================== */
.zaza-video-section {
    text-align: center;
    margin: 35px 20px;
    padding: 35px 20px;
    background: rgba(26, 111, 255, 0.04);
    border-radius: 24px;
    border: 1px solid rgba(26, 111, 255, 0.15);
    position: relative;
    overflow: hidden;
}

.video-title {
    color: #c8a96e;
    font-size: 1.8rem;
    margin-bottom: 22px;
    text-transform: uppercase;
    letter-spacing: 4px;
}

.video-container {
    position: relative;
    max-width: 200px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.8),
        0 0 35px rgba(26, 111, 255, 0.2);
    border: 2px solid rgba(26, 111, 255, 0.2);
}

.zaza-play-btn {
    width: 90px; height: 90px;
    border-radius: 25%;
    background: linear-gradient(135deg, #1a3a80, #0a2555);
    border: 3px solid rgba(200, 169, 110, 0.4);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow:
        0 0 25px rgba(26, 111, 255, 0.45),
        0 0 50px rgba(26, 111, 255, 0.2);
    transition: all 0.3s;
    animation: playPulse 2.5s ease-in-out infinite;
}

@keyframes playPulse {
    0%, 100% { box-shadow: 0 0 25px rgba(26, 111, 255, 0.45); }
    50%       { box-shadow: 0 0 45px rgba(26, 111, 255, 0.7), 0 0 80px rgba(232, 74, 0, 0.2); }
}

.zaza-play-btn:hover {
    transform: scale(1.12);
    background: linear-gradient(135deg, #3d1a00, #280f00);
    box-shadow: 0 0 50px rgba(232, 74, 0, 0.55);
    border-color: rgba(232, 74, 0, 0.5);
}

.play-icon {
    font-size: 2.2rem;
    color: #7aaeff;
    margin-left: 4px;
    transition: color 0.3s;
}

.zaza-play-btn:hover .play-icon { color: #e09060; }

.video-overlay {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0, 0, 0, 0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s;
    backdrop-filter: blur(1px);
}

.video-overlay.hidden { opacity: 0; pointer-events: none; }

.video-controls {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, transparent 100%);
    padding: 25px 15px 15px;
    transform: translateY(100%);
    transition: transform 0.3s;
}

.video-container:hover .video-controls { transform: translateY(0); }

.progress-container {
    width: 100%; height: 4px;
    background: rgba(255,255,255,0.1);
    border-radius: 2px;
    cursor: pointer;
    position: relative;
    margin-bottom: 8px;
}

.progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #e84a00, #1a6fff);
    border-radius: 2px;
    width: 0%;
}

.progress-handle {
    position: absolute;
    top: 50%;
    width: 12px; height: 12px;
    background: #c8a96e;
    border-radius: 25%;
    transform: translate(-50%, -50%) scale(0);
    left: 0%;
    transition: transform 0.2s;
}

.progress-container:hover .progress-handle { transform: translate(-50%, -50%) scale(1); }

.controls-row {
    display: flex;
    justify-content: space-between;
    color: #5a8ae0;
    font-size: 0.85rem;
    font-weight: 600;
}

.time-display { color: #5a8ae0; }

/* ==========================================
   SCROLLBAR
   ========================================== */
::-webkit-scrollbar { width: 10px; }

::-webkit-scrollbar-track { background: var(--negro); }

::-webkit-scrollbar-thumb {
    background: linear-gradient(180deg, #1a3a80, #3d1a00, #1a3a80);
    border-radius: 5px;
    border: 2px solid var(--negro);
}

::-webkit-scrollbar-thumb:hover {
    background: linear-gradient(180deg, #1a6fff, #e84a00, #1a6fff);
}

/* ==========================================
   RESPONSIVE
   ========================================== */
@media (max-width: 1200px) {
    #albumes-container { grid-template-columns: repeat(3, 1fr); }
}

@media (max-width: 900px) {
    #albumes-container { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
    .zaza-title      { font-size: 2.4rem; letter-spacing: 4px; }
    .logo-img        { width: 140px; height: 140px; }
    .perfil-card     { width: 90%; max-width: 350px; }
    .player-container { width: 90%; max-width: 400px; height: 200px; }
    .modal-content   { padding: 28px 18px; width: 95%; }
    
    #albumes-container {
        grid-template-columns: repeat(2, 1fr);
        gap: 16px;
        padding: 30px 12px;
    }
    
    .album-title  { font-size: 1rem; }
    .album-desc   { font-size: 0.8rem; }
    .zaza-play-btn { width: 72px; height: 72px; }
    .play-icon    { font-size: 1.8rem; }
    .video-title  { font-size: 1.4rem; }
}

@media (max-width: 480px) {
    #albumes-container { grid-template-columns: 1fr; }
    .zaza-play-btn { width: 58px; height: 58px; }
    .play-icon    { font-size: 1.4rem; }
    .access-btn   { padding: 14px 30px; font-size: 0.95rem; }
}
    </style>
</body>
