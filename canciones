/* ==========================================
   ✨ PARTÍCULAS - BRASAS FLOTANTES
   ========================================== */
.particles {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: -1;
}

.particle {
    position: absolute;
    width: 4px;
    height: 4px;
    background: var(--fuxia);
    border-radius: 25%;
    animation: ashFloat 15s infinite;
    opacity: 0.6;
    box-shadow: 0 0 10px currentColor;
}

.particle:nth-child(3n) {
    background: var(--verde);
    width: 3px;
    height: 3px;
}

.particle:nth-child(5n) {
    background: var(--amarillo);
    width: 5px;
    height: 5px;
    animation-duration: 12s;
}

@keyframes ashFloat {
    0% {
        transform: translateY(100vh) translateX(0) rotate(0deg);
        opacity: 0;
    }
    10% {
        opacity: 1;
    }
    90% {
        opacity: 0.6;
    }
    100% {
        transform: translateY(-100vh) translateX(100px) rotate(720deg);
        opacity: 0;
    }
}

